PORT=3000

# Email address that receives booking notifications
RECIPIENT_EMAIL=your@email.com

# Resend email
RESEND_API_KEY=re_...

# Maksekeskus
MAKSEKESKUS_SHOP_ID=your_shop_id
MAKSEKESKUS_SECRET_KEY=your_secret_key
MAKSEKESKUS_ENV=production

# Site URL (for redirects after payment)
SITE_URL=https://nutritallinn.onrender.com
